{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://italian-vocabulary.local/schema.json",
  "title": "Vocabulary (YAML)",
  "description": "Expected shape for *.yaml files in this directory: a non-empty array of lexemes with forms, sense groups, and glosses.",
  "type": "array",
  "minItems": 1,
  "items": {
    "$ref": "#/$defs/definition"
  },
  "$defs": {
    "definition": {
      "type": "object",
      "properties": {
        "word": { "type": "string" },
        "forms": {
          "type": "array",
          "items": { "$ref": "#/$defs/form" },
          "minItems": 1
        }
      },
      "required": ["word", "forms"],
      "additionalProperties": false
    },
    "form": {
      "type": "object",      
      "properties": {
        "word": { "type": "string" },
        "pos": { "enum": ["s. m.", "s. f.", "agg.", "v. tr.", "v. intr.", "v. tr. pron.", "v. intr. pron.", "v. rifl."] },
        "syl": { "type": ["null", "string"] },
        "props": {
          "type": ["null", "object"],
          "properties": {
            "pl_m": { "type": "string" },
            "pl_f": { "type": "string" },
            "f": { "type": "string" },
            "aus": { "enum": ["avere", "essere"] },
            "pres": { "type": "string" },
            "fut": { "type": "string" },
            "pass_rem": { "type": "string" },
            "part_pass": { "type": "string" },
            "superl": { "type": "string" },
            "coniug": { "type": "string" }
          },
          "minProperties": 1,
          "additionalProperties": false
        },
        "tags": {
          "type": ["null", "array"],
          "items": { "type": "string" },
          "minItems": 1
        },
        "hints": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "senses": {
          "type": "array",
          "items": { "$ref": "#/$defs/sense" },
          "minItems": 1
        }
      },
      "required": ["pos", "syl", "props", "tags", "hints", "senses"],
      "additionalProperties": false
    },
    "sense": {
      "type": "object",
      "properties": {
        "glosses": {
          "type": "array",
          "items": { "$ref": "#/$defs/gloss" },
          "minItems": 1
        }
      },
      "required": ["glosses"],
      "additionalProperties": false
    },
    "gloss": {
      "type": "object",      
      "properties": {
        "gloss": { "type": "string" },
        "tags": {
          "type": ["null", "array"],
          "items": { "type": "string" },
          "minItems": 1
        },
        "props": {
          "type": ["null", "object"],
          "properties": {
            "sin": { "type": "string" },
            "contr": { "type": "string" },
            "prep": { 
              "type": "array",
              "items": { "enum": ["a", "in", "su", "per", "con", "da", "di", "tra", "fra"] },
              "minItems": 1
            }
          },
          "minProperties": 1,
          "additionalProperties": false
        },
        "examples": {
          "type": ["null", "array"],
          "items": { "type": "string" },
          "minItems": 1
        },
        "phrases": {
          "type": ["null", "array"],
          "items": { "$ref": "#/$defs/phrase" },
          "minItems": 1
        }
      },
      "required": ["gloss", "props", "tags", "examples", "phrases"],
      "additionalProperties": false
    },
    "phrase": {
      "type": "object",
      "properties": {
        "phrase": { "type": "string" },
        "tags": {
          "type": ["null", "array"],
          "items": { "type": "string" },
          "minItems": 1
        },
        "glosses": {
          "type": "array",
          "items": { 
            "type": "object",
            "properties": {
              "gloss": { "type": "string" },
              "tags": {
                "type": ["null", "array"],
                "items": { "type": "string" },
                "minItems": 1
              }
            },
            "minProperties": 1,
            "additionalProperties": false
          }
        },
        "examples": {
          "type": ["null", "array"],
          "items": { "type": "string" },
          "minItems": 1
        }
      },
      "additionalProperties": false
    }
  }
}
